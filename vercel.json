{
  "cleanUrls": true,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/leadership", "destination": "/index.html" },
    { "source": "/scholarship", "destination": "/index.html" },
    { "source": "/strategy", "destination": "/index.html" },
    { "source": "/roadmap", "destination": "/index.html" },
    { "source": "/contact", "destination": "/index.html" },
    { "source": "/sources", "destination": "/index.html" },
    { "source": "/access", "destination": "/index.html" },
    { "source": "/dashboard", "destination": "/index.html" }
  ]
}
