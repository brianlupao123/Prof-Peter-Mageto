# ── Local Development Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore.

# ── Neon PostgreSQL (Required for backend API) ────────────────────────────────
# Get this from: https://console.neon.tech → your project → Connection string
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Admin credentials ─────────────────────────────────────────────────────────
# These override the hardcoded defaults. Set them before seeding the admin user.
ADMIN_EMAIL=profmagteo@gmail.com
ADMIN_PASSWORD=YourStrongPasswordHere

# ── JWT signing secret ────────────────────────────────────────────────────────
# Any long random string. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-your-random-secret

# ── Email delivery via Resend (Optional — contact form notifications) ─────────
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
# The inbox email that receives contact form submissions
NOTIFY_EMAIL=profmagteo@gmail.com

# ── Vercel Blob (Optional — for uploading portrait photos via admin dashboard) ─
# Get this from: https://vercel.com/dashboard → Storage → Blob → your store
BLOB_READ_WRITE_TOKEN=vercelblob_rw_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Local API port ────────────────────────────────────────────────────────────
PORT=3001
